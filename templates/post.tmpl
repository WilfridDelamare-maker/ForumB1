<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <article>
        <h1>{{ .Post.Title }}</h1>
        <p>{{ .Post.Content }}</p>
        <small>
            Auteur : {{ .Post.Author }} — Catégorie : {{ .Post.Category }}
        </small>
    </article>

    {{ range .Comments }}
        <section>
            <p>{{ .Content }}</p>
            <small>Par {{ .Author }}</small>
        </section>
    {{ else }}
        <p>Aucun commentaire pour le moment.</p>
    {{ end }}

    <form action="/posts/{{ .Post.ID }}/comments" method="POST">
        <textarea class="comment" name="content" placeholder="Qu'avez-vous à dire ?" required></textarea>
        <button class="tohover" type="submit">Ajouter un commentaire...</button>
    </form>
</body>
</html>
