<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer un post</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <header>
        <a class="brand tohover" href="/">Forum name</a>
        <form class="search" action="/" method="GET">
            <input type="text" name="q" placeholder="Rechercher...">
            <button class="tohover" type="submit">OK</button>
        </form>
        <nav class="authNav">
            {{ if .IsLogged }}
            <form method="POST" action="/logout">
                <button class="tohover" type="submit">Se déconnecter</button>
            </form>
            {{ else }}
            <a class="tohover" href="register">S'inscrire</a>
            <a class="tohover" href="login">Se connecter</a>
            {{ end }}
        </nav>
    </header>

    <h1>Créer un post</h1>
    <form class="post-create-form" action="/posts/create" method="POST" enctype="multipart/form-data">
        <label for="title">Titre</label>
        <input type="text" id="title" name="title" required>

        <label for="content">Contenu</label>
        <textarea id="content" class="comment" name="content" required></textarea>

        <label for="image">Ajouter Image</label>
        <input type="file" id="image" name="image" accept="image/png, image/jpeg, image/webp, image/gif">

        <div class="category-checkboxes">
            {{ range .Categories }}
            <label class="category-option" for="category-{{ .ID }}">
                <input type="checkbox" id="category-{{ .ID }}" name="categories" value="{{ .ID }}">
                <span>{{ .Name }}</span>
            </label>
            {{ end }}
        </div>

        {{ if .Error }}
            <p class="errorText">{{ .Error }}</p>
        {{ end }}

        <button type="submit">Publier</button>
    </form>
</body>
</html>
