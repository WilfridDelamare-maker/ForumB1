<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forum</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <header>
        <a class="brand tohover" href="/">PostHub</a>
        <form class="search" action="/" method="GET">
            <input type="text" name="q" placeholder="Rechercher...">
            <button class="tohover" type="submit">OK</button>
        </form>
        <nav class="authNav">
            {{ if .IsLogged }}
            <form method="POST" action="/logout">
                <button class="tohover" type="submit">Se déconnecter</button>
            </form>
            {{ else }}
            <a class="tohover" href="/register">S'inscrire</a>
            <a class="tohover" href="/login">Se connecter</a>
            {{ end }}
        </nav>
    </header>

    <main class="layout">
        <nav id="sideNav">
            <a class="tohover">Populaires</a>
            <a href="/categories"class="tohover">Categories</a>
            <a href="/random" class="tohover">Page aleatoire</a>
            {{ if .IsLogged }}
            <a href="/posts/create" class="tohover">Créer un post</a>
            {{ else }}
            <a href="/login" class ="tohover">Connectez vous pour poster</a>
            {{ end }}
        </nav>

        <section class="feed">
            {{ range .Posts }}
            <article class="data">
                <h3>
                    <a href="/posts/{{ .ID }}">{{ .Title }}</a>
                </h3>
                <p>{{ .Content }}</p>
                <small>{{ .Author }} - {{ .Category }}</small>
            </article>
            {{ else }}
            <p class="data">Rien pour le moment... Soyez le premier à poster !</p>
            {{ end }}
        </section>
    </main>
</body>
</html>
