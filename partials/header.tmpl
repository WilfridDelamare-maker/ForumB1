{{ define "header" }}

<header>
    <a class="brand tohover" href="/">PostHub</a>
    <form class="search" action="/" method="GET">
        <input type="text" name="q" placeholder="Rechercher...">
        <button class="tohover" type="submit">OK</button>
    </form>

    <form method="POST" action="/theme">
        <button type="submit" class="darklightmode">
            {{ if .DarkMode }}
            <img src="/static/logos/light-mode.png">
            {{ else }}
            <img src="/static/logos/dark-mode.png">
            {{ end }}
        </button>
    </form>
    
    <nav class="authNav">
        {{ if .Username }}
        <p class="">{{ .Username }}</p>
        {{ end }}
        {{ if .IsLogged }}
        <form method="POST" action="/logout">
            <button class="tohover" type="submit">Se déconnecter</button>
        </form>
        {{ else }}
        <a class="tohover" href="/register">S'inscrire</a>
        <a class="tohover" href="/login">Se connecter</a>
        {{ end }}
    </nav>
</header>

{{ end }}